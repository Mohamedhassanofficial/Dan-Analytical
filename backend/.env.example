# Copy to `.env` and fill in. The .env file is read by pydantic-settings
# (see app/core/config.py). Never commit the real .env.

# --- App ---
APP_ENV=development
DEBUG=true

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tadawul
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/tadawul
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Financial defaults (overridable via admin UI) ---
DEFAULT_RISK_FREE_RATE=0.0475
DEFAULT_LOOKBACK_DAYS=1260
TRADING_DAYS_PER_YEAR=252

# --- Market data ---
YFINANCE_REFRESH_HOUR_UTC=20
YFINANCE_MAX_RETRIES=3
YFINANCE_REQUEST_TIMEOUT_SEC=30

# --- Security (Phase B) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-real-random-value-at-least-32-chars-long
ACCESS_TOKEN_TTL_MIN=30
BCRYPT_ROUNDS=12

# --- Payment (Phase B) ---
PAYMENT_GATEWAY=stcpay
SUBSCRIPTION_PRICE_SAR=199.0
SUBSCRIPTION_DURATION_DAYS=30

# --- Compliance ---
AUDIT_LOG_RETENTION_DAYS=730
PDPL_DATA_REGION=KSA
